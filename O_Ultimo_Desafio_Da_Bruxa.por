     funcao contexto ()
    {
      inteiro i
      
      // Insere uma linha antes do texto da mensagem		
      escreva("\n","\n")
      letra_por_letra ("BEM VINDO(A) AO JOGO! \n")
      letra_por_letra ("Gênero: Terror / Suspense \n")
      escreva("\n","\n")
      u.aguarde  (150)
      
      para(i = 0; i < 220; i++)
      {
        
        escreva ("-")
        
      }
      u.aguarde(150)
      escreva("\n","\n","\n","\n")                                                                                                                                 
      escreva("                                      ▄████▄   ▄▄ ▄▄ ▄▄   ▄▄▄▄▄▄ ▄▄ ▄▄   ▄▄  ▄▄▄    ▄▄▄▄  ▄▄▄▄▄  ▄▄▄▄  ▄▄▄  ▄▄▄▄▄ ▄▄  ▄▄▄    ▄▄▄▄   ▄▄▄    ▄▄▄▄  ▄▄▄▄  ▄▄ ▄▄ ▄▄ ▄▄  ▄▄▄  \n")
      escreva("*********************************     ██  ██   ██ ██ ██     ██   ██ ██▀▄▀██ ██▀██   ██▀██ ██▄▄  ███▄▄ ██▀██ ██▄▄  ██ ██▀██   ██▀██ ██▀██   ██▄██ ██▄█▄ ██ ██ ▀█▄█▀ ██▀██      *********************************\n")
      escreva("                                      ▀████▀   ▀███▀ ██▄▄▄  ██   ██ ██   ██ ▀███▀   ████▀ ██▄▄▄ ▄▄██▀ ██▀██ ██    ██ ▀███▀   ████▀ ██▀██   ██▄█▀ ██ ██ ▀███▀ ██ ██ ██▀██ \n")
      escreva("\n","\n","\n")  
      u.aguarde(150)

      para(i = 0; i <220; i++)
      {
        escreva ("-")
      }
      u.aguarde(1000) 
      escreva("\n","\n","\n")                                                                                                                               
      letra_por_letra("Você está de férias em uma casa simples em frente a praia do Saquinho, no Sul da ilha de Florianópolis.\n")
      u.aguarde(500) 
      escreva("\n") 
      letra_por_letra("Após um dia incrível na praia, curtindo a natureza você decide deitar em sua cama para relaxar.\n")
      u.aguarde(500)
      escreva("\n") 
      letra_por_letra("Você olha para a janela e vê as folhas das árvores que balançam com a brisa fresca de verão.\n")
      u.aguarde(500) 
      escreva("\n") 
      letra_por_letra("O balançar das folhas é tão relaxante que voce adormece.\n")
      u.aguarde(500) 
      escreva("\n") 
      letra_por_letra("Às  0️⃣3️⃣:0️⃣0️⃣ da madrugada seu celular vibra com uma notificação de mensagem. \n")
      u.aguarde(500) 
      escreva("\n") 
      letra_por_letra("Ainda sonolento, você percebe que onde deveria ter um número de contato,  havia apenas um espaço em branco.\n")
      u.aguarde(500 ) 
      escreva("\n")
      escreva("\n") 
      escreva("Pressione ENTER para LER a mensagem:")
      leia(enter)
      limpa()

      
    }

