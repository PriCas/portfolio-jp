              } enquanto (leuGrimorio == falso)
                  

                        
  
            caso contrario:
              escreva("\n⚠️ Erro:  ' ", opcao, " 'É uma Opção inválida!\n")
              escreva("\nPor favor, escolha apenas entre os números 1, 2 ou 3 para digitar.\n")
              u.aguarde(3000)
              limpa()
              pare
              
    
              
        }
      
      }enquanto (opcaoValida == falso)
        
    }
