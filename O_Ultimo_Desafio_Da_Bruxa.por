    //Animação tela piscando comp completa (com dialogos).
    funcao prepTelaLigada(){

    //Aqui começa a animação do celular piscando.    

     letra_por_letra("\n\nVocê vê a tela do seu celular piscando,\n")
     u.aguarde(1000)
     letra_por_letra("\nindicando que a câmera traseira foi ligada.\n")
     u.aguarde(1000)
     letra_por_letra("\nA lente mostra uma realidadade alternativa.\n")
     u.aguarde(1000)
     letra_por_letra("\nvocê vê uma mulher usando um vestido antigo e chapéu pontudo.\n")
     u.aguarde(1000)
     escreva("\n\nPressione ENTER para continuar:")
     leia(enter)
     limpa()

     TELADESLIGADA()
     u.aguarde(1000)
     limpa()
     TELALIGADA()
     u.aguarde(200)
     limpa()
     TELADESLIGADA()
     u.aguarde(1000)
     limpa()
     TELALIGADA()
     u.aguarde(200)
     limpa()    
     TELACAMERA()
     u.aguarde(500)
     limpa()
     TELADESLIGADA()
     u.aguarde(1000)
     limpa()    
     TELALIGADA()
     u.aguarde(200)
     limpa()
     TELACAMERA()
     u.aguarde(500)
     limpa()
     TELAVESTIDO()
     u.aguarde(1000)
     limpa()
     TELACAMERA()
     u.aguarde(200)
     limpa()
     TELAVESTIDO()
     u.aguarde(1000)

    //Aqui aparece o frame da bruxa na janela e o texto.

     u.aguarde(1000)
    
     limpa()
     mulherJ()
     letra_por_letra("\n\nA mulher caminhou até a janela do barraco em que ela se encontrava e observou a vista.\n")
     u.aguarde(500)
     letra_por_letra("\nVocê observa o horizonte e percebe que é a mesma praia que você está agora, mas com mais árvores ao redor.\n")
     u.aguarde(500)
     letra_por_letra("\nSim, de alguma forma ela estava te mostrando a visão dela.\n")
     u.aguarde(500)
     letra_por_letra("\n\nPressione ENTER para continuar:")
     leia(enter)
     limpa()

    

    }
