                  escreva("                   ####+--.|__________________________|    +.+##+++---                              \n")
                  escreva("                  #####++-. __________________________     +..+##++-----                            \n")
                  escreva("                  #####+--.|Sinto que recuperei meus  |    +.+-++##++----                           \n")
                  escreva("                  ###++--..|poderes e que minha alma  |    +.+  ++#+++++---                         \n")
                  escreva("                 ########+.|está livre.               |    -.-+  ++######+---                       \n")
                  escreva("                 ######++--|__________________________|    -.------+#######+---+                    \n")
                  escreva("                 #####+--.. ____________                   -..-----+#####++++----                   \n")
                  escreva("                ########+-.| Obrigada   |                  -..--+########++++---#                   \n")
                  escreva("                 ++###++-..|____________|                  -..+########++++----                    \n")
                  escreva("                       ++-.   ___________________________  -..########++++----+                     \n")
                  escreva("                         +.- |________________________|__| ..########++++-----                      \n")
                  escreva("                            -.............................-#########+++++-----                      \n")
                  escreva("                              ####++###+++-++--+-+++++++############++++-----+                      \n")
                  escreva("                                #+######++##++++++#+##############+++++------                       \n")
                  escreva("                                   ###########+#++###############++++---------                      \n")
                  escreva("                                      #########################+++-----++-------+                   \n")
                  escreva("                                         ########+###########+++++++-----++++-----++                \n")
                  escreva("                                            #+###+#######+++++++++++++++++++++++-----+              \n")
                  escreva("                                                ######+++++-+++++######+++-++--+++++++---           \n")
                  escreva("                                                    +++++++++++++#########++--++++++++++---         \n")
                  escreva("                                                          +++++++########+###+--+++++++++++---      \n")
                  escreva("                                                            ####+##############+--+++++++++++---+   \n")
                  u.aguarde(4000)
                  bruxaVoando()

          }
          senao
          {
              respostaCertaD4Nome = falso 
                             
                se (respostaCertaD4Nome == falso e vidaAtual > 0)
                {  
                    danoJogador = danoJogador + 1
                    vidaAtual = vidaAtual - 1 
                    historicoJogador [4] = vidaAtual
                    tentativasRestantes = vidaJogadorInicio - danoJogador

                    escreva("\n Voce perdeu ", danoJogador,  " pontos até agora.")
                    escreva("\n Sua pontuação atual é = ",vidaAtual,".")
                    escreva("\n Voce possui  " , tentativasRestantes,  "tentativas restantes. " )         
                  //  escreva("\n [DEBUG] Vetor pontos do jogador na posição [0], inicio do jogo =  ",historicoJogador [0] )
                  //  escreva("\n [DEBUG] Vetor pontos do jogador na posição [1]  = ",historicoJogador [1] )
                  //  escreva("\n [DEBUG] Vetor pontos do jogador na posição [2] = ",historicoJogador [2] )
                  //  escreva("\n [DEBUG] Vetor pontos do jogador na posição [3] = ",historicoJogador [3] )
                  //  escreva("\n [DEBUG] Vetor pontos do jogador na posição [4] = ",historicoJogador [4] )
                   // escreva("\n [DEBUG] Tentativas restantes  = ",tentativasRestantes )
                }  

                se (respostaCertaD4Nome == falso e vidaAtual == 0)
                {   
                    limpa()
                    escreva("  ╔════════════════════════════════════════════╗\n")
                    escreva("  ║            ❌ VOCE FALHOU! ❌             ║\n")
                    escreva("  ╚════════════════════════════════════════════╝\n") 
                    escreva("\n")
                    escreva("  ╔════════════════════════════════════════════╗\n")
                    escreva("  ║⚰️⚰️⚰️⚰️⚰️⚰️⚰️GAME OVER!⚰️⚰️⚰️⚰️⚰️⚰️⚰️ ║\n")
                    escreva("  ╚════════════════════════════════════════════╝\n")
                    escreva(" Suas tentativas acabaram.\n\n")
                    escreva(" A escuridão prevaleceu.\n\n")
                    escreva(" 💀 Vida restante: ", vidaAtual, " pontos 💀\n\n")
                    escreva("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n")
                    u.aguarde(500)
                    fimDoJogo()
                    retorne  // SAI DA FUNÇÃO COMPLETAMENTE

                } 
                escreva("\n Pressione ENTER para TENTAR novamente \n")
                leia(enter)
                limpa() 
                
                  
              }
                

        }enquanto (respostaCertaD4Nome == falso)
    }

    

