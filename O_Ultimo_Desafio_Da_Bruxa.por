    funcao letra_por_letra(cadeia texto)
    {
        inteiro tam = t.numero_caracteres(texto)
        para (inteiro i = 0; i < tam; i++)
        {
            escreva(t.extrair_subtexto(texto, i, i + 1))
            u.aguarde(20)
        }
    }  
    funcao escolhaGarrafas()
    {
      para (i = 0 ; i <  10 ; i++)
