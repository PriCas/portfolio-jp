      }
      funcao itemColetado ()
      {  
        para(i = 0 ; i < 4; i++)
        {
          limpa()
          u.aguarde(50)
          escreva("\n","\n")
          escreva("+-+-+-+-+ +-+-+-+-+-+-+-+-+ +-+-+-+ +-+-+-+-+-+-+-+-+\n")
          escreva(" |i|t|e|m| |c|o|l|e|t|a|d|o| |c|o|m| |s|u|c|e|s|s|o|!|\n")
          escreva(" +-+-+-+-+ +-+-+-+-+-+-+-+-+ +-+-+-+ +-+-+-+-+-+-+-+-+\n")
          u.aguarde(750)
          limpa()

          
        }
      }
    
}
      

