      funcao piscaGrimorio()
      {
        para(i = 0 ; i < 4 ; i++)
        {
          limpa()
          u.aguarde(30)
          grimorioPrint()
          u.aguarde(150)
          limpa()
        }
      }
      funcao grimorioPrint()
      {
              escreva(".                                                                                                   \n")
              escreva("                                                                                                    \n")
              escreva("                                                                                                    \n")
              escreva("                                                                                                    \n")
              escreva("                             -...........................-                                          \n")
              escreva("                          -.#      #...............       #..                                       \n")
              escreva("                         --                                +.                                       \n")
              escreva("                         --      ;+.  .        .  :;.      +.                                       \n")
              escreva("                         --   ::;&:;.:.         .:.:+X;;.  +.                                       \n")
              escreva("                         --   :..:;                .;.:.:  +.                                       \n")
              escreva("                         --  :X:     PURIFICAÇÃO       +x. +.+                                      \n")
              escreva("                         --  .+.:       DA           .:.+. +.+                                      \n")
              escreva("                         -.  ...;     BENTA           +... +.+                                      \n")
              escreva("                         -.   .:                       :   +.+                                      \n")
              escreva("                   ##++---.  .x.  ÁGUA DA NASCENTE   ... . +..--++                                  \n")
              escreva("                   ++++-.-.  .:;X   MANDRÁGORA       ;+:;  +..##+-+                                 \n")
              escreva("                      +---.  ...+: COLHIDA NO SOL      ;+. +.+##+--                                 \n")
              escreva("                         -.   ..    POENTE             :   +.###++--                                \n")
              escreva("                   ####+--.  . .x  MEL PURO DE       .x .  +.+##+++---                              \n")
              escreva("                  #####++-.  :+..  BOCA-DE-RENDA      .:x. +..+##++-----                            \n")
              escreva("                  #####+--.  :$:                       +x. +.+-++##++----                           \n")
              escreva("                  ###++--..   :..:;                 ..:.;  +.+  ++#+++++---                         \n")
              escreva("                 ########+.  ..::.+..:           ;.:; ;;.  -.-+  ++######+---                       \n")
              escreva("                 ######++--   .  ;;.  .         .  .;:     -.------+#######+---+                    \n")
              escreva("                 #####+--..                                -..-----+#####++++----                   \n")
              escreva("                ########+-.                                -..--+########++++---#                   \n")
              escreva("                 ++###++-..                                -..-########+++++---+                    \n")
              escreva("                   #------.                                -..+########++++----                     \n")
              escreva("                       ++-.   ___________________________  -..########++++----+                     \n")
              escreva("                         +.- |________________________|__| ..########++++-----                      \n")
              escreva("                            -.............................-#########+++++-----                      \n")
              escreva("                              ####++###+++-++--+-+++++++############++++-----+                      \n")
              escreva("                                #+######++##++++++#+##############+++++------                       \n")
              escreva("                                   ###########+#++###############++++---------                      \n")
              escreva("                                      #########################+++-----++-------+                   \n")
              escreva("                                         ########+###########+++++++-----++++-----++                \n")
