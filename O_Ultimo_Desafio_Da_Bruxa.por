programa
{
  inclua biblioteca Util --> u //para u.aguarde
  //inclua biblioteca Graficos --> g // Importa a biblioteca gráfica
  inclua biblioteca Texto --> tx //para extrair texto
  inclua biblioteca Texto --> t //para contar caracteres do texto


  // Variáveis Globais
  cadeia enter, opcao, respostaJogadorD3_1, respostaJogadorD4Nome
  logico opcaoValida, respostaCertaD3_1, respostaCertaD4Nome, leuGrimorio, voltarMenu
  inteiro historicoJogador[10]//vetor que recebe a pontuação do jogador em cada etapa. 
  inteiro historicoPalitos[3] 
  inteiro tentativasRestantes, danoJogador, danoPalito , i , vidaJogadorInicio, vidaAtual , palitosRestantes, palitosAtual, palitosI, respostaI//variaveis que controlam as chances do jogador
  //inteiro escolha_erva, ing1, ing2, ing3 //Victor - caminho alternativo.
  cadeia ing1 , ing2 , ing3 

  funcao inicio()   
  { 
    
    


    //logo jovem programador
    logoJovemP() //Chama o procecimento //descomentar

    //creditos jovem programador 2026
    jovemPLegivelPisca() 
    jovemPBloodPisca()
    jovemPLegivelPisca()
    jovemPBloodPisca()
    jovemPBloodEstatica()
    jovemPBloodPisca()
    jovemPEstatica1()//descomentar
    jovemPBloodEstatica()//descomentar
    jovemPEstatica2() //descomentar

    //creditos senac
    senacLegivelPisca()
    senacBloodPisca()
    senacLegivelPisca()
    senacBloodPisca()
    senacBloodEstatica ()
    senacBloodPisca()
    senacLegivelEstatica1()//descomentar
    senacBloodEstatica ()//descomentar
    senacLegivelEstatica2() //descomentar

    //creditos seprosc
    seproscLegivelPisca() 
    seproscBloodPisca()
    seproscLegivelPisca()
    seproscBloodPisca()
    seproscBloodEstatica ()
    seproscBloodPisca()
    seproscLegivelEstatica1()//descomentar
    seproscBloodEstatica () //descomentar
    seproscLegivelEstatica2() //descomentar

    //nome do jogo 
    nomeJogoBloodPisca()
    nomeJogoLegivelPisca()
    nomeJogoBloodPisca()
    nomeJogoLegivelEstatica1() 
    nomeJogoBloodEstatica()
    nomeJogoLegivelEstatica2() 

    contexto() //descomentar
    PrepMostrarMensagens1()
    prepTelaLigada()//descomentar

     
    dialogoDesafio1() //descomentar
    menuDesafio1()
    

    
    
   
    
  }

  
